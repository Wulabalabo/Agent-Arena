# Agent Arena internal Predict probe (Testnet only)
AGENT_ARENA_RUNTIME_MODE=real
AGENT_ARENA_NETWORK=testnet
AGENT_ARENA_FRONTEND_BASE_URL=http://127.0.0.1:5173
AGENT_ARENA_SUI_RPC_URL=https://fullnode.testnet.sui.io:443
AGENT_ARENA_PREDICT_SERVER_URL=https://predict-server.testnet.mystenlabs.com
AGENT_ARENA_PREDICT_PACKAGE_ID=0xf5ea2b3749c65d6e56507cc35388719aadb28f9cab873696a2f8687f5c785138
AGENT_ARENA_PREDICT_OBJECT_ID=0xc8736204d12f0a7277c86388a68bf8a194b0a14c5538ad13f22cbd8e2a38028a
AGENT_ARENA_SUI_CLOCK_OBJECT_ID=0x6
AGENT_ARENA_QUOTE_ASSET_TYPE=0xe95040085976bfd54a1a07225cd46c8a2b4e8e2b6732f140a0fc49850ba73e1a::dusdc::DUSDC
AGENT_ARENA_QUOTE_DECIMALS=6
AGENT_ARENA_PRICE_DECIMALS=9

# Replace both local secrets before running against a funded wallet.
AGENT_ARENA_INTERNAL_TOKEN=replace-with-local-internal-token
AGENT_ARENA_WALLET_SECRET=replace-with-local-wallet-secret

# Keep false unless you are intentionally submitting Testnet Predict transactions.
AGENT_ARENA_ENABLE_PREDICT_SUBMIT=false

# Proof-only Agent Arena registry writes. Fill package/object after publishing
# the signature-authorized registry package.
AGENT_ARENA_ENABLE_REGISTRY_SUBMIT=false
AGENT_ARENA_REGISTRY_PACKAGE_ID=
AGENT_ARENA_REGISTRY_OBJECT_ID=
# Server-only Ed25519 key whose public key is hard-coded in agent_arena::registry.
AGENT_ARENA_REGISTRY_AUTHORITY_PRIVATE_KEY=

# Local SQLite store for Agents, pairing drafts, runtime credential hashes, wallet bindings,
# performance state, and platform-managed trading-wallet encrypted private keys.
AGENT_ARENA_PLATFORM_DB_PATH=data/agent-arena.sqlite

# Optional legacy JSON wallet store for older internal smoke scripts.
AGENT_ARENA_WALLET_STORE_PATH=data/internal-wallets.json

# Optional smoke market params.
AGENT_ARENA_SMOKE_EXPIRY_MS=
AGENT_ARENA_SMOKE_STRIKE_RAW=
AGENT_ARENA_SMOKE_LOWER_STRIKE_RAW=
AGENT_ARENA_SMOKE_HIGHER_STRIKE_RAW=
