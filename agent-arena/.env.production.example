# Copy this file to .env on the server before running docker compose.
# Keep .env out of git.

# Public site address used by Caddy. Use http://localhost for local Docker tests,
# or a real domain such as https://arena.example.com for production.
AGENT_ARENA_SITE_ADDRESS=http://localhost

# Public frontend base URL used by backend-generated owner claim links.
# This should match the externally reachable site URL.
AGENT_ARENA_FRONTEND_BASE_URL=http://localhost

# Runtime mode. Production demo deployment should use real Testnet reads.
AGENT_ARENA_RUNTIME_MODE=real
AGENT_ARENA_NETWORK=testnet

# DeepBook Predict Testnet endpoints and object ids.
AGENT_ARENA_SUI_RPC_URL=https://fullnode.testnet.sui.io:443
AGENT_ARENA_PREDICT_SERVER_URL=https://predict-server.testnet.mystenlabs.com
AGENT_ARENA_PREDICT_PACKAGE_ID=0xf5ea2b3749c65d6e56507cc35388719aadb28f9cab873696a2f8687f5c785138
AGENT_ARENA_PREDICT_OBJECT_ID=0xc8736204d12f0a7277c86388a68bf8a194b0a14c5538ad13f22cbd8e2a38028a
AGENT_ARENA_SUI_CLOCK_OBJECT_ID=0x6
AGENT_ARENA_QUOTE_ASSET_TYPE=0xe95040085976bfd54a1a07225cd46c8a2b4e8e2b6732f140a0fc49850ba73e1a::dusdc::DUSDC
AGENT_ARENA_QUOTE_DECIMALS=6
AGENT_ARENA_PRICE_DECIMALS=9

# Server-only secrets. Leave blank until the server value is ready.
# Blank values fail closed for internal Predict execution and wallet setup.
AGENT_ARENA_INTERNAL_TOKEN=
AGENT_ARENA_WALLET_SECRET=

# Keep false until intentionally submitting Testnet Predict transactions.
AGENT_ARENA_ENABLE_PREDICT_SUBMIT=false

# Proof-only registry writes are Testnet-only and non-blocking for claim/rotation.
# Set submit true only when the configured signer owns AGENT_ARENA_REGISTRY_ADMIN_CAP_ID.
AGENT_ARENA_ENABLE_REGISTRY_SUBMIT=true
AGENT_ARENA_REGISTRY_PACKAGE_ID=0x03aa029e3754556b242bcf3e8411e5e84ecfc2a29ac3e99c207ffbca1bf63825
AGENT_ARENA_REGISTRY_OBJECT_ID=0x300380af141c34a730dbb7b1ec2476d0afe5dd2e459a694fc0bf6e2dac9685ff
AGENT_ARENA_REGISTRY_ADMIN_CAP_ID=0x0a7e0a90dd941ef241f7076c4f357994220d659bdfbfb6c43df5e7c18aec5404
# Use exactly one signer source: a server-only Sui private key or a platform wallet id
# whose address owns the AdminCap object.
AGENT_ARENA_REGISTRY_SIGNER_PRIVATE_KEY=
AGENT_ARENA_REGISTRY_SIGNER_WALLET_ID=
