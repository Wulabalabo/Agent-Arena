{
  "name": "agent-arena",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.11",
  "scripts": {
    "dev": "bun run scripts/dev.ts",
    "dev:backend": "bun run --cwd apps/backend dev",
    "dev:frontend": "bun run --cwd apps/frontend dev",
    "smoke:attribution": "bun run --cwd apps/backend smoke:attribution",
    "smoke:predict": "bun run --cwd apps/backend smoke:predict",
    "smoke:platform": "bun run apps/backend/src/platform-contract-smoke.ts",
    "validate:skills": "bun run scripts/validate-skills.ts",
    "test:backend": "bun run --cwd apps/backend test",
    "test:frontend": "bun run --cwd apps/frontend test",
    "typecheck": "bun run --cwd apps/frontend typecheck",
    "build": "bun run --cwd apps/frontend build"
  }
}
